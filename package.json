{
  "name": "node-rest-reference-architecture",
  "version": "1.0.0",
  "description": "A production-ready, highly optimized Node.js REST API reference architecture.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --env-file=.env dist/index.js",
    "dev": "nodemon --exec ts-node --env-file=.env src/index.ts",
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles",
    "prepare": "husky"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "architecture",
    "reference",
    "sota"
  ],
  "author": {
    "name": "Jan Esser",
    "email": "jan@janesser.net",
    "url": "https://janesser.net"
  },
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.8.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
